#!/bin/sh
echo "Running pre-commit checks..."

echo "→ Type checking..."
pnpm exec tsc --noEmit || {
  echo "✗ Type check failed. Fix errors before committing."
  exit 1
}

echo "→ Building..."
pnpm build || {
  echo "✗ Build failed. Fix errors before committing."
  exit 1
}

echo "✓ All checks passed."
